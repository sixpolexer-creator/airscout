# AirScout — environment variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local — it is git-ignored.

# ── LLM (required for AI ranking + semantic search) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Flight data adapters (optional — mock adapter always runs as fallback) ────
DUFFEL_TOKEN=duffel_live_...

# ── Graph database — Neo4j / AuraDB / Memgraph (Step 3) ─────────────────────
# Leave unset to skip graph features; mock adapter covers all search paths.
GRAPH_DB_URI=bolt://localhost:7687
GRAPH_DB_USER=neo4j
GRAPH_DB_PASSWORD=airscout

# ── Redis cache (Step 5) ─────────────────────────────────────────────────────
# Leave unset to disable predictive caching; live search path is unaffected.
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=airscout-dev

# ── Agent pipeline (Step 2) ──────────────────────────────────────────────────
# "local" (default) | "n8n" | "mcp"
AGENT_DISPATCH_MODE=local
N8N_WEBHOOK_URL=https://<your-n8n-host>/webhook/<workflow-id>
MCP_SERVER_URL=http://localhost:3100

# ── Prefetch worker (Step 5) ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
